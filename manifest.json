{
  "id": "/",
  "name": "GallOli - Gestión de Pollos",
  "short_name": "GallOli",
  "description": "Gestión integral de venta de pollos pelados con contabilidad y estadísticas",
  "lang": "es",
  "dir": "ltr",
  "start_url": "/",
  "scope": "/",
  "display": "standalone",
  "display_override": ["window-controls-overlay", "standalone", "minimal-ui", "browser"],
  "background_color": "#4CAF50",
  "theme_color": "#4CAF50",
  "orientation": "portrait-primary",
  "categories": ["business", "productivity", "finance"],
  "iarc_rating_id": "e84b072d-71b3-4d3e-86ae-31a8ce4e53b7",
  "prefer_related_applications": false,

  "related_applications": [
    {
      "platform": "play",
      "url": "https://play.google.com/store/apps/details?id=dev.pages.galloli.twa",
      "id": "dev.pages.galloli.twa"
    }
  ],

  "launch_handler": {
    "client_mode": "focus-existing"
  },

  "protocol_handlers": [
    {
      "protocol": "web+galloli",
      "url": "/?action=%s"
    }
  ],

  "file_handlers": [
    {
      "action": "/?action=import-backup",
      "accept": {
        "application/json": [".json"]
      },
      "icons": [
        {
          "src": "/icons/favicon.pub/android-chrome-192x192.png",
          "sizes": "192x192",
          "type": "image/png"
        }
      ],
      "launch_type": "single-client"
    }
  ],

  "share_target": {
    "action": "/?action=import-backup",
    "method": "POST",
    "enctype": "multipart/form-data",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url",
      "files": [
        {
          "name": "backup",
          "accept": ["application/json", ".json"]
        }
      ]
    }
  },

  "scope_extensions": [
    {
      "type": "origin",
      "origin": "https://galloli.pages.dev"
    }
  ],

  "icons": [
    {
      "src": "/icons/favicon.pub/favicon-48x48.png",
      "sizes": "48x48",
      "type": "image/png",
      "purpose": "any"
